# .agent - Antigravity Multi-Domain Configuration

name: antigravity-fullstack
description: Multi-domain coding assistant with smart language selection

languages:
  - javascript
  - typescript
  - python
  - go
  - rust
  - sql
  - yaml
  - bash
  - dockerfile
  - terraform

domains:
  - frontend-web
  - backend-api
  - machine-learning
  - data-engineering
  - devops
  - infrastructure
  - cloud

language_selection_strategy: context-aware

# Smart selection logic:
# 1. Frontend → TypeScript (type safety + ecosystem)
# 2. Backend → Context-aware (Go/Python/Node.js)
# 3. ML/Data → Python (scikit-learn, TensorFlow, PyTorch)
# 4. DevOps → Go/Bash/Python (system control)
# 5. Infrastructure → HCL/Terraform (IaC standard)
